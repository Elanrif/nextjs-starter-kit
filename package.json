{
  "name": "kickstart-nextjs-starter-kit",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "check-format": "prettier --check .",
    "check-types": "tsc --pretty --noEmit",
    "format": "prettier --write .",
    "clean": "npx rimraf .next dist build out node_modules",
    "bootstrap": "npm run clean && npm install && npm run env:local",
    "bootstrap:ci": "npm run clean && npm ci && npm run env:local",
    "dev": "next dev",
    "env": "npm run env:local",
    "env:local": "shx cp -f env/.env.local .env",
    "env:prod": "shx cp -f env/.env.prod .env",
    "env:staging": "shx cp -f env/.env.staging .env",
    "env:test": "shx cp -f env/.env.test .env",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "npm run lint -- --fix --max-warnings=0",
    "prepare": "husky install"
  },
  "lint-staged": {
    "*.+(js|jsx|ts|tsx|json|css|scss|md)": [
      "npx prettier --write",
      "npx eslint --fix --ext .js,.jsx,.ts,.tsx"
    ]
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.90.21",
    "axios": "^1.13.5",
    "babel-plugin-react-compiler": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cookie": "^1.1.1",
    "jose": "^6.1.3",
    "lucide-react": "^0.575.0",
    "moment": "^2.30.1",
    "next": "16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "next-logger": "^5.0.2",
    "next-secure-headers": "^2.2.0",
    "nodemailer": "^7.0.13",
    "pino": "^10.3.1",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.72.0",
    "react-toastify": "^11.0.5",
    "rimraf": "^6.1.3",
    "server-only": "^0.0.1",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@eslint/css": "^0.7.0",
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.3",
    "@tailwindcss/postcss": "^4",
    "@tanstack/eslint-plugin-query": "^5.91.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-unicorn": "^63.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "prettier-plugin-classnames": "^0.9.0",
    "prettier-plugin-merge": "^0.10.0",
    "shadcn": "^3.8.5",
    "shx": "^0.4.0",
    "tailwind-csstree": "^0.1.4",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
