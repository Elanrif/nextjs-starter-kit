# This file contains environment variables for the local production environment.
ENV=staging

# Server-side variables
CACHE_EXPIRE_TIME=900
XXX_SITENAME=www.XXX.elanrif.com
LOCALE_DEFAULT=fr

# Features flags
NEXT_PUBLIC_ENABLE_SEO_FEATURE=false

# Alert message
NEXT_PUBLIC_DISPLAY_ALERT=false

# Browser-side variables
NEXT_PUBLIC_ALT_WEBSITE_URL=http://localhost:3000
NEXT_PUBLIC_ROOT_DOMAIN=localhost
NEXT_PUBLIC_GRAPHQL_ENDPOINT="http://XXX/graphql/"
NEXT_PUBLIC_WEBSITE_URL=http://localhost:3000

# Session and cookie: ✅ openssl rand -base64 32 ou ⚠️ echo -n "code" | openssl base64
SESSION_SECRET=dvX8+pHjkfzrnHrNwoM0VLcj0n1OMauIHfshNAQq3kw=
COOKIE_SECRET=ERP2IDSV+rUYjY83n7kSKyKwUGOSAt8ardU6gfNsuos=
COOKIE_SAME_SITE=lax
COOKIE_SECURE=false
COOKIE_HTTP_ONLY=true

# Auth
BETTER_AUTH_SECRET=d3d5c98d5cbecc7482e9a9ebc0e3e59beff6355f5ee39067a11810753410ce14
BETTER_AUTH_URL=$NEXT_PUBLIC_WEBSITE_URL

# API
AUTH_KEYS_ANON_CLIENT_ID=demo.website
AUTH_KEYS_ANON_CLIENT_SECRET=changeit
AUTH_KEYS_OWN_CLIENT_ID=a2Vja3N0YXJ0LW5leHRqcy10ZW1wbGF0ZS1jbGllbnQtaWQ=
