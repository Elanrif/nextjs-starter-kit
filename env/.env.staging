XXX_BASEURL=http://localhost:8081

# CORS
CORS_ALLOWED_ORIGIN=*

# Docker
DOCKER_USER_GID=root
DOCKER_USER_UID=root

# Formatting
FORMAT_CURRENCY_GROUPING=true
FORMAT_CURRENCY_SCALE=2
FORMAT_DATETIME_ISO=YYYY-MM-DDThh:mm:ss

# HTTP
HTTP_REDIRECT_ENABLED=android
HTTP_REQUEST_APPEND_SLASH=true
HTTP_REQUEST_REPEAT_DELAY_MILLISECONDS=15000
HTTP_REQUEST_REPEAT_MAX_ATTEMPTS=4
HTTP_REQUEST_TIMEOUT_MILLISECONDS=60000

# Locale
LOCALE_COUNTRY_DEFAULT_COUNTRY=FR
NEXT_PUBLIC_DEFAULT_CURRENCY=EUR

# Log
LOG_FILE_PATH=logs/server.log
LOG_FORMAT=simple
LOG_LEVEL=DEBUG
LOG_OUTPUT=console
NEXT_PUBLIC_LOG_FORMAT=simple
NEXT_PUBLIC_LOG_LEVEL=DEBUG
NEXT_PUBLIC_LOG_OUTPUT=console

# Message
MESSAGE_DURATION=3000

# Pagination
PAGINATION_LIMIT=20
PAGINATION_SCROLL_THRESHOLD=10

# Preview
PREVIEW_INIT_ITEMS=10
PREVIEW_MIN_ITEMS=5

# Search
SEARCH_HISTORY_MAX_ITEMS=5
SEARCH_INPUT_MAX_LENGTH=30
SEARCH_RATIO_MAX_WIDTH=0.6

# SMTP Configuration (for password reset and email notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
# https://myaccount.google.com/apppasswords
